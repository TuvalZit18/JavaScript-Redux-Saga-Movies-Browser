# .gitignore — files and folders excluded from Git version control
# These are never committed to the repository.

# Dependencies
node_modules/

# Environment variables — keep your API key private!
.env
.env.local
.env.*.local

# Build output
dist/
build/

# Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
